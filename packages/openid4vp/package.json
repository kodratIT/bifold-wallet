{
  "name": "@bifold/openid4vp",
  "version": "0.1.0",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "./lib/commonjs/index.js",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "import": "./lib/module/index.js",
      "require": "./lib/commonjs/index.js",
      "types": "./lib/typescript/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openwallet-foundation/bifold-wallet.git",
    "directory": "packages/openid4vp"
  },
  "homepage": "https://github.com/openwallet-foundation/bifold-wallet/",
  "files": [
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "yarn clean && bob build",
    "clean": "rimraf ./lib",
    "test": "TZ=GMT jest",
    "coverage": "TZ=GMT jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/curves": "2.0.1",
    "@openid4vc/oauth2": "0.5.1",
    "@openid4vc/openid4vp": "0.5.1",
    "did-resolver": "^4.1",
    "jose": "^5.10"
  },
  "devDependencies": {
    "@babel/core": "~7.28.6",
    "@peculiar/x509": "^1.14.3",
    "@react-native/babel-preset": "~0.81.5",
    "@types/jest": "~29.5.14",
    "babel-jest": "~29.7.0",
    "jest": "~29.6.4",
    "react-native-builder-bob": "~0.21.3",
    "rimraf": "~5.0.10",
    "typescript": "~5.9.2"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  }
}
