{
  "name": "@bifold/ui",
  "version": "1.0.0",
  "description": "Custom UI components for Bifold Wallet",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "./lib/commonjs/index.js",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "import": "./lib/module/index.js",
      "require": "./lib/commonjs/index.js",
      "types": "./lib/typescript/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openwallet-foundation/bifold-wallet.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/openwallet-foundation/bifold-wallet/",
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "echo 'building ui 🏗️' && yarn clean && bob build && echo 'ui built ✅'",
    "clean": "rimraf ./lib",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@babel/core": "~7.28.6",
    "@babel/runtime": "~7.28.6",
    "@expo/app-integrity": "^55.0.9",
    "@react-navigation/native": "~6.0.16",
    "@react-navigation/stack": "~6.3.29",
    "@types/react": "~19.1.9",
    "@types/react-native-vector-icons": "~6.4.18",
    "react": "*",
    "react-i18next": "~11.17.1",
    "react-native": "*",
    "react-native-builder-bob": "~0.21.3",
    "react-native-keychain": "~10.0.0",
    "react-native-permissions": "~5.4.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-uuid": "~2.0.3",
    "react-native-vector-icons": "~10.3.0",
    "rimraf": "~5.0.10",
    "typescript": "~5.9.2"
  },
  "peerDependencies": {
    "@expo/app-integrity": ">=55.0.0",
    "@react-navigation/native": ">=6.0.0",
    "@react-navigation/stack": ">=6.0.0",
    "react": ">=18.0.0",
    "react-i18next": ">=11.0.0",
    "react-native": ">=0.70.0",
    "react-native-keychain": ">=9.0.0",
    "react-native-permissions": ">=5.0.0",
    "react-native-safe-area-context": ">=4.0.0",
    "react-native-uuid": ">=2.0.0",
    "react-native-vector-icons": ">=9.0.0"
  },
  "dependencies": {
    "@bifold/core": "workspace:*"
  },
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  }
}
